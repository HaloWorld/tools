#!/bin/sh
set -eu

repo_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
desktop_dir="$repo_dir/apps/desktop"

fail() {
  echo "ERROR: $*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fail "required command not found: $1"
}

if [ "$(uname -s)" != "Darwin" ]; then
  fail "Universal Tools desktop install currently supports macOS only"
fi

[ -d "$desktop_dir" ] || fail "missing desktop app directory: $desktop_dir"
[ -f "$desktop_dir/package.json" ] || fail "missing desktop package.json"

require_command cargo
require_command npm
require_command codesign
require_command ditto

echo "Preparing Universal Tools desktop app..."
cd "$desktop_dir"

if [ ! -d node_modules ]; then
  echo "Installing desktop app dependencies..."
  npm ci
fi

echo "Building and verifying latest local app..."
npm run release:local

echo "Installing Universal Tools..."
npm run install:local

echo
echo "Universal Tools is installed."
echo "App: ${UT_LOCAL_INSTALL_DIR:-"$HOME/Applications"}/Universal Tools.app"
echo
echo "To install the optional shell commands as well, run:"
echo "  UT_LINK_CLI=1 UT_LOCAL_BIN_DIR=\"\$HOME/.local/bin\" ./install"
